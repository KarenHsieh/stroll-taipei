# Mapbox public access token.
# Obtain one from https://account.mapbox.com/access-tokens/
# Copy this file to .env.local and fill in the value.
# .env.local is git-ignored; .env.example stays in version control as the setup template.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Postgres connection string used by the server and CLI scripts.
# Local (docker-compose.yml starts postgres:17 on 5432 with these creds):
DATABASE_URL=postgres://stroll:stroll@localhost:5432/stroll
# Zeabur: the official Postgres template injects DATABASE_URL into the Next.js
# service via service-to-service variable injection — do not set it manually.
